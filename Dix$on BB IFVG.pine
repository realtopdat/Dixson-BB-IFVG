                array.set(tradeStopLines, i, na), array.set(tradeStopLabels, i, na)
            endNow = dir == 1 ? (hitHi >= tpV or hitLo <= stopV) : (hitLo <= tpV or hitHi >= stopV)
            if endNow
                array.set(tradeIsActive, i, false)
