alertcondition(enableAlerts and bullIfvgConfirmedAlert, "Bullish BB IFVG Confirmed", "Dix$on BB IFVG: Bullish IFVG confirmed from a bearish FVG.")
alertcondition(enableAlerts and bearIfvgConfirmedAlert, "Bearish BB IFVG Confirmed", "Dix$on BB IFVG: Bearish IFVG confirmed from a bullish FVG.")
alertcondition(enableAlerts and bullEntryAlert, "Bullish BB IFVG Entry", "Dix$on BB IFVG: Bullish entry confirmed from lower-band context and bullish IFVG.")
alertcondition(enableAlerts and bearEntryAlert, "Bearish BB IFVG Entry", "Dix$on BB IFVG: Bearish entry confirmed from upper-band context and bearish IFVG.")
alertcondition(enableAlerts and bullTrendlineBreakAlert, "Bullish Trendline Break", "Dix$on BB IFVG: Bullish trendline break confirmed.")
alertcondition(enableAlerts and bearTrendlineBreakAlert, "Bearish Trendline Break", "Dix$on BB IFVG: Bearish trendline break confirmed.")
