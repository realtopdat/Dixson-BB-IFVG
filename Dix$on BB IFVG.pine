biasDir = (close > selectedBasis or bullBreakRecent) and not bearBreakRecent ? 1 : (close < selectedBasis or bearBreakRecent) and not bullBreakRecent ? -1 : 0
biasTxt = biasDir == 1 ? "Bullish" : biasDir == -1 ? "Bearish" : "Neutral"

