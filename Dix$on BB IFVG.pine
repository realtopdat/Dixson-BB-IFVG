        f_dashCell(performanceDashboard, 0, 3, "Wins", color.white, dashLabelBg, dashboardTextSizeInput), f_dashCell(performanceDashboard, 1, 3, str.tostring(statWins), color.white, dashBullBg, dashboardTextSizeInput)
        f_dashCell(performanceDashboard, 0, 4, "Losses", color.white, dashLabelBg, dashboardTextSizeInput), f_dashCell(performanceDashboard, 1, 4, str.tostring(statLosses), color.white, dashBearBg, dashboardTextSizeInput)
        f_dashCell(performanceDashboard, 0, 5, "BE", color.white, dashLabelBg, dashboardTextSizeInput), f_dashCell(performanceDashboard, 1, 5, str.tostring(statBreakevens), color.white, dashBeBg, dashboardTextSizeInput)
