        f_dashCell(liveDashboard, 0, 1, "BB State", color.white, dashLabelBg, dashboardTextSizeInput), f_dashCell(liveDashboard, 1, 1, bbState, color.white, dashNeutralBg, dashboardTextSizeInput)
        f_dashCell(liveDashboard, 0, 2, "Last Band Touch", color.white, dashLabelBg, dashboardTextSizeInput), f_dashCell(liveDashboard, 1, 2, lastTouchTxt, color.white, dashNeutralBg, dashboardTextSizeInput)
