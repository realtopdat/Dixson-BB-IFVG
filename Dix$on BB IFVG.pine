            dir = array.get(dashTradeDirs, i), entryV = array.get(dashTradeEntries, i), stopV = array.get(dashTradeStops, i), beV = array.get(dashTradeBEs, i), tpV = array.get(dashTradeTPs, i), moved = array.get(dashTradeMovedToEntry, i)
            beHit = dir == 1 ? hitHi >= beV : hitLo <= beV
            if not moved and beHit
                array.set(dashTradeMovedToEntry, i, true), array.set(dashTradeStops, i, entryV), stopV := entryV, moved := true
            tpHit = dir == 1 ? hitHi >= tpV : hitLo <= tpV
            stopHit = dir == 1 ? hitLo <= stopV : hitHi >= stopV
