    array.push(tradeEntryLabels, lbE), array.push(tradeStopLabels, lbS), array.push(tradeBeLabels, lbB), array.push(tradeR2Labels, lb2), array.push(tradeR3Labels, lb3)
    array.push(tradeDirs, dir), array.push(tradeIsActive, true), array.push(tradeStops, stopV), array.push(tradeBEs, beV), array.push(tradeTps, endTradeLevel == "1R" ? beV : endTradeLevel == "3R" ? r3V : r2V), array.push(tradeEntries, entryV), array.push(tradeMovedToEntry, false)

if longSignal
    latestBearSignalDone := true, pendingBullRetest := false, bullEntryAlert := true, statTotalSignals += 1, statLongSignals += 1
    barsWin = math.max(3, bar_index - (latestBearFvgBar - 2) + 1)
    entryV = close, stopV = math.min(ta.lowest(low, barsWin), entryV - syminfo.mintick), riskV = math.max(entryV - stopV, syminfo.mintick)
    beV = entryV + riskV, r2V = entryV + riskV * 2.0, r3V = entryV + riskV * 3.0, tpV = endTradeLevel == "1R" ? beV : endTradeLevel == "3R" ? r3V : r2V
    f_addDashTrade(1, entryV, stopV, riskV, beV, tpV)
    if showEntries
        array.push(bullEntries, label.new(bar_index, low - entryOffset, "Long", style=label.style_label_up, color=longEntryLabelColor, textcolor=entryLabelTextColor, size=labelSz))
    if showIfvgEntryZones
        [entryFvgBox, entryFvgMid] = f_createEntryFvgVisual(latestBearFvgBar - 2, latestBearTop, latestBearBottom, bullFvgColor, fvgTransparency, showMidline, midlineColor, midlineStyleInput)
        array.push(bullEntryFvgBoxes, entryFvgBox), array.push(bullEntryFvgLabels, f_createCoreFvgLabel(bar_index, latestBearTop, latestBearBottom, "IFVG", bullFvgColor))
        if not na(entryFvgMid)
            array.push(bullEntryFvgMidlines, entryFvgMid)
    if showTradeLevels
