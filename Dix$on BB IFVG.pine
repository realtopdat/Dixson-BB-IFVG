// Alerts group placeholder: alertconditions are gated by Master > Enable Alerts.

//━━━━━━━━━━━━━━━━━━━━
// Helpers
//━━━━━━━━━━━━━━━━━━━━
f_ma(string maType, series float src, int len) =>
    maType == "EMA" ? ta.ema(src, len) : maType == "RMA" ? ta.rma(src, len) : maType == "WMA" ? ta.wma(src, len) : maType == "VWMA" ? ta.vwma(src, len) : ta.sma(src, len)

f_bb(series float src, int len, float mult, string maType) =>
    basis = f_ma(maType, src, len)
    dev = ta.stdev(src, len) * mult
    upper = basis + dev
    lower = basis - dev
    width = basis != 0.0 ? (upper - lower) / basis * 100.0 : na
    pctB = (upper - lower) != 0.0 ? (close - lower) / (upper - lower) : na
    [basis, upper, lower, width, pctB]

f_midlineStyle(string style) => style == "Solid" ? line.style_solid : style == "Dashed" ? line.style_dashed : line.style_dotted
f_labelSize(string s) => s == "Tiny" ? size.tiny : s == "Small" ? size.small : s == "Large" ? size.large : s == "Huge" ? size.huge : size.normal
f_dashboardPosition(string s) => s == "Top Left" ? position.top_left : s == "Bottom Right" ? position.bottom_right : s == "Bottom Left" ? position.bottom_left : position.top_right
f_dashboardTextSize(string s) => s == "Small" ? size.small : s == "Normal" ? size.normal : size.tiny
f_fmtPrice(float v) => na(v) ? "—" : str.tostring(v, format.mintick)
f_fmtPct(float v) => na(v) ? "—" : str.tostring(v, "#.0") + "%"
f_fmtR(float v) => na(v) ? "—" : (v > 0 ? "+" : "") + str.tostring(v, "#.00") + "R"
f_tpRValue(string tpMode) => tpMode == "1R" ? 1.0 : tpMode == "3R" ? 3.0 : 2.0
f_dashClampTransp(int t) => math.min(100, math.max(0, t))
f_dashCell(table tbl, int col, int row, string txt, color txtColor, color bgColor, string txtSize) => table.cell(tbl, col, row, txt, text_color=txtColor, bgcolor=bgColor, text_size=f_dashboardTextSize(txtSize))

f_sizeValue(float top, float bottom, string mode, float atrV) =>
    absSize = math.abs(top - bottom)
    mode == "Points/Dollars" ? absSize : mode == "Ticks" ? absSize / syminfo.mintick : mode == "Percent" ? (absSize / close) * 100.0 : atrV == 0.0 ? 0.0 : absSize / atrV

f_lowerInteraction(float lowerBand, string mode) =>
    wickTouch = low <= lowerBand
    bodyTouch = math.min(open, close) <= lowerBand
    closeOutside = close < lowerBand
    reclaim = close[1] < lowerBand[1] and close > lowerBand
    mode == "Wick Touch" ? wickTouch : mode == "Body Touch" ? bodyTouch : mode == "Close Outside" ? closeOutside : mode == "Reclaim Inside" ? reclaim : (wickTouch or bodyTouch or closeOutside or reclaim)

f_upperInteraction(float upperBand, string mode) =>
    wickTouch = high >= upperBand
    bodyTouch = math.max(open, close) >= upperBand
    closeOutside = close > upperBand
    reclaim = close[1] > upperBand[1] and close < upperBand
    mode == "Wick Touch" ? wickTouch : mode == "Body Touch" ? bodyTouch : mode == "Close Outside" ? closeOutside : mode == "Reclaim Inside" ? reclaim : (wickTouch or bodyTouch or closeOutside or reclaim)

f_cleanupVisuals(array<box> boxesArr, array<line> linesArr, int cap) =>
    if cap > 0
        while array.size(boxesArr) > cap
            b = array.shift(boxesArr)
            box.delete(b)
        while array.size(linesArr) > cap
            l = array.shift(linesArr)
            line.delete(l)

f_cleanupLabels(array<label> labelsArr, int cap) =>
    if cap > 0
        while array.size(labelsArr) > cap
            lb = array.shift(labelsArr)
            label.delete(lb)

f_makeTradeLevel(float y, string txt, color col, int w) =>
    line ln = line.new(bar_index, y, bar_index, y, color=col, width=w, extend=extend.none)
    label lb = label.new(bar_index, y, txt + " / $" + str.tostring(y, format.mintick), style=label.style_label_left, textcolor=col, color=color.new(color.black, 100), yloc=yloc.price, size=size.tiny)
    [ln, lb]

f_createCoreFvgLabel(int rightBar, float top, float bottom, string txt, color fvgColor) =>
    label.new(rightBar, (top + bottom) * 0.5, txt, xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_right, color=color.new(color.black, 100), textcolor=color.new(fvgColor, 0), size=size.tiny)

f_updateCoreFvgLabel(label lb, int rightBar, float top, float bottom, string txt, color fvgColor) =>
    if not na(lb)
        label.set_x(lb, rightBar), label.set_y(lb, (top + bottom) * 0.5), label.set_text(lb, txt), label.set_textcolor(lb, color.new(fvgColor, 0))

f_labelAttachX(label lb, int fallbackBar) => not na(lb) ? label.get_x(lb) : fallbackBar

f_createEntryFvgVisual(int leftBar, float top, float bottom, color fvgColor, int transp, bool drawMid, color midColor, string midStyle) =>
    newEntryBox = box.new(leftBar, top, bar_index, bottom, border_color=color.new(fvgColor, 0), bgcolor=color.new(fvgColor, transp), extend=extend.none)
    line newEntryMid = na
    if drawMid
        mid = (top + bottom) * 0.5
        newEntryMid := line.new(leftBar, mid, bar_index, mid, color=midColor, style=f_midlineStyle(midStyle), extend=extend.none)
    [newEntryBox, newEntryMid]

f_deleteTradeAt(int i, array<line> eL, array<line> sL, array<line> bL, array<line> r2L, array<line> r3L, array<label> eLb, array<label> sLb, array<label> bLb, array<label> r2Lb, array<label> r3Lb, int[] dirs, bool[] active, float[] stops, float[] bes, float[] tps, float[] entries, bool[] moved) =>
    line lnE = array.get(eL, i), lnS = array.get(sL, i), lnB = array.get(bL, i), ln2 = array.get(r2L, i), ln3 = array.get(r3L, i)
    label lbE = array.get(eLb, i), lbS = array.get(sLb, i), lbB = array.get(bLb, i), lb2 = array.get(r2Lb, i), lb3 = array.get(r3Lb, i)
    if not na(lnE)
        line.delete(lnE)
    if not na(lnS)
        line.delete(lnS)
    if not na(lnB)
        line.delete(lnB)
    if not na(ln2)
        line.delete(ln2)
    if not na(ln3)
        line.delete(ln3)
    if not na(lbE)
        label.delete(lbE)
    if not na(lbS)
        label.delete(lbS)
    if not na(lbB)
        label.delete(lbB)
    if not na(lb2)
        label.delete(lb2)
    if not na(lb3)
        label.delete(lb3)
    array.remove(eL, i), array.remove(sL, i), array.remove(bL, i), array.remove(r2L, i), array.remove(r3L, i)
    array.remove(eLb, i), array.remove(sLb, i), array.remove(bLb, i), array.remove(r2Lb, i), array.remove(r3Lb, i)
    array.remove(dirs, i), array.remove(active, i), array.remove(stops, i), array.remove(bes, i), array.remove(tps, i), array.remove(entries, i), array.remove(moved, i)

f_lineValue(line ln) =>
    not na(ln) ? line.get_price(ln, bar_index) : na

//━━━━━━━━━━━━━━━━━━━━
// Core Series
//━━━━━━━━━━━━━━━━━━━━
atrValue = ta.atr(atrLength)
bbTfReq = bbTf == "" ? timeframe.period : bbTf
[bbBasis, bbUpper, bbLower, bbBandwidth, bbPercentB] = request.security(syminfo.tickerid, bbTfReq, f_bb(bbSource, bbLength, bbMult, bbMaType), barmerge.gaps_off, barmerge.lookahead_off)
[htfBasis, htfUpper, htfLower, htfBandwidth, htfPercentB] = request.security(syminfo.tickerid, htfBbTf, f_bb(htfBbSource, htfBbLength, htfBbMult, htfBbMaType), barmerge.gaps_off, barmerge.lookahead_off)

chartUpperPlot = plot(showBb ? bbUpper : na, "BB Upper", color=bbUpperColor, linewidth=bbWidth)
chartBasisPlot = plot(showBb and showBbBasis ? bbBasis : na, "BB Basis", color=bbBasisColor, linewidth=bbWidth)
chartLowerPlot = plot(showBb ? bbLower : na, "BB Lower", color=bbLowerColor, linewidth=bbWidth)
fill(chartUpperPlot, chartLowerPlot, color=(showBb and showBandFill) ? color.new(bbUpperColor, bbFillOpacity) : na, title="BB Fill")
htfUpperPlot = plot(showHtfBb and useHtfBandsForDisplay ? htfUpper : na, "HTF BB Upper", color=htfBbUpperColor, linewidth=htfBbWidth)
htfBasisPlot = plot(showHtfBb and useHtfBandsForDisplay ? htfBasis : na, "HTF BB Basis", color=htfBbBasisColor, linewidth=htfBbWidth)
htfLowerPlot = plot(showHtfBb and useHtfBandsForDisplay ? htfLower : na, "HTF BB Lower", color=htfBbLowerColor, linewidth=htfBbWidth)
fill(htfUpperPlot, htfLowerPlot, color=(showHtfBb and useHtfBandsForDisplay and htfBbFill and showBandFill) ? color.new(htfBbUpperColor, htfBbFillOpacity) : na, title="HTF BB Fill")

sessionVwap = ta.vwap(sessionVwapSource)
sessionVwapBullOk = not useSessionVwapFilter or (not na(sessionVwap) and close > sessionVwap)
sessionVwapBearOk = not useSessionVwapFilter or (not na(sessionVwap) and close < sessionVwap)
plot(showSessionVwap ? sessionVwap : na, "Session VWAP", color=close >= sessionVwap ? bullFvgColor : bearFvgColor, linewidth=sessionVwapWidth)

// Band touch state.
chartLowerTouch = f_lowerInteraction(bbLower, bandInteractionType)
chartUpperTouch = f_upperInteraction(bbUpper, bandInteractionType)
htfLowerTouch = useHtfBandsForEntry and f_lowerInteraction(htfLower, bandInteractionType)
htfUpperTouch = useHtfBandsForEntry and f_upperInteraction(htfUpper, bandInteractionType)
chartLowerRecent = bandTouchLookback == 0 ? chartLowerTouch : ta.barssince(chartLowerTouch) <= bandTouchLookback
chartUpperRecent = bandTouchLookback == 0 ? chartUpperTouch : ta.barssince(chartUpperTouch) <= bandTouchLookback
htfLowerRecent = bandTouchLookback == 0 ? htfLowerTouch : ta.barssince(htfLowerTouch) <= bandTouchLookback
htfUpperRecent = bandTouchLookback == 0 ? htfUpperTouch : ta.barssince(htfUpperTouch) <= bandTouchLookback
lowerBandContextNow = bandTouchSource == "Chart Bands" ? chartLowerRecent : bandTouchSource == "HTF Bands" ? htfLowerRecent : bandTouchSource == "Chart or HTF" ? (chartLowerRecent or htfLowerRecent) : (chartLowerRecent and htfLowerRecent)
upperBandContextNow = bandTouchSource == "Chart Bands" ? chartUpperRecent : bandTouchSource == "HTF Bands" ? htfUpperRecent : bandTouchSource == "Chart or HTF" ? (chartUpperRecent or htfUpperRecent) : (chartUpperRecent and htfUpperRecent)

var int lastLowerBandTouchBar = na
var int lastUpperBandTouchBar = na
var string lastLowerBandTouchSourceText = "None"
var string lastUpperBandTouchSourceText = "None"
if chartLowerTouch or htfLowerTouch
    lastLowerBandTouchBar := bar_index
    lastLowerBandTouchSourceText := chartLowerTouch and htfLowerTouch ? "Both" : chartLowerTouch ? "Chart" : "HTF"
if chartUpperTouch or htfUpperTouch
    lastUpperBandTouchBar := bar_index
    lastUpperBandTouchSourceText := chartUpperTouch and htfUpperTouch ? "Both" : chartUpperTouch ? "Chart" : "HTF"

f_contextRecent(int touchBar) => not requireFvgAfterBandTouch or (not na(touchBar) and (maxBarsBandTouchToFvg == 0 or bar_index - touchBar <= maxBarsBandTouchToFvg))
lowerFvgContext = lowerBandContextNow and f_contextRecent(lastLowerBandTouchBar)
upperFvgContext = upperBandContextNow and f_contextRecent(lastUpperBandTouchBar)

//━━━━━━━━━━━━━━━━━━━━
// State Storage
//━━━━━━━━━━━━━━━━━━━━
var array<box> bullBoxes = array.new<box>()
var array<box> bearBoxes = array.new<box>()
var array<box> bullEntryFvgBoxes = array.new<box>()
var array<box> bearEntryFvgBoxes = array.new<box>()
var array<line> bullMidlines = array.new<line>()
var array<line> bearMidlines = array.new<line>()
var array<line> bullEntryFvgMidlines = array.new<line>()
var array<line> bearEntryFvgMidlines = array.new<line>()
var array<label> bullFvgLabels = array.new<label>()
var array<label> bearFvgLabels = array.new<label>()
var array<label> bullEntries = array.new<label>()
var array<label> bearEntries = array.new<label>()
var array<label> bullEntryFvgLabels = array.new<label>()
var array<label> bearEntryFvgLabels = array.new<label>()
var array<line> trendlines = array.new<line>()
var array<line> tradeEntryLines = array.new<line>()
var array<line> tradeStopLines = array.new<line>()
var array<line> tradeBeLines = array.new<line>()
var array<line> tradeR2Lines = array.new<line>()
var array<line> tradeR3Lines = array.new<line>()
var array<label> tradeEntryLabels = array.new<label>()
var array<label> tradeStopLabels = array.new<label>()
var array<label> tradeBeLabels = array.new<label>()
var array<label> tradeR2Labels = array.new<label>()
var array<label> tradeR3Labels = array.new<label>()
var int[] tradeDirs = array.new_int()
var int[] dashTradeDirs = array.new_int()
var bool[] tradeIsActive = array.new_bool()
var bool[] tradeMovedToEntry = array.new_bool()
var bool[] dashTradeActive = array.new_bool()
var bool[] dashTradeMovedToEntry = array.new_bool()
var float[] tradeStops = array.new_float()
var float[] tradeBEs = array.new_float()
var float[] tradeTps = array.new_float()
var float[] tradeEntries = array.new_float()
var float[] dashTradeEntries = array.new_float()
var float[] dashTradeStops = array.new_float()
var float[] dashTradeBEs = array.new_float()
var float[] dashTradeTPs = array.new_float()
var float[] dashTradeRisks = array.new_float()
var table liveDashboard = table.new(position.bottom_right, 2, 13, bgcolor=color.new(color.black, 100), frame_color=color.new(color.gray, 70), frame_width=1, border_color=color.new(color.gray, 80), border_width=1)
var table performanceDashboard = table.new(position.top_right, 2, 10, bgcolor=color.new(color.black, 100), frame_color=color.new(color.gray, 70), frame_width=1, border_color=color.new(color.gray, 80), border_width=1)

var int latestBullFvgBar = na
var int latestBearFvgBar = na
var int latestBullIfvgBar = na
var int latestBearIfvgBar = na
var float latestBullTop = na
var float latestBullBottom = na
var float latestBearTop = na
var float latestBearBottom = na
var bool latestBullActive = false
var bool latestBearActive = false
var bool latestBullIfvgConfirmed = false
var bool latestBearIfvgConfirmed = false
var bool latestBullSignalDone = false
var bool latestBearSignalDone = false
var bool latestBullUpperContext = false
var bool latestBearLowerContext = false
var box latestBullBox = na
var box latestBearBox = na
var line latestBullMidline = na
var line latestBearMidline = na
var label latestBullFvgLabel = na
var label latestBearFvgLabel = na
var bool pendingBullRetest = false
var bool pendingBearRetest = false
var int pendingBullRetestBar = na
var int pendingBearRetestBar = na

var int statTotalSignals = 0
var int statLongSignals = 0
var int statShortSignals = 0
var int statClosedTrades = 0
var int statWins = 0
var int statLosses = 0
var int statBreakevens = 0
var float statNetR = 0.0
var float statGrossWinR = 0.0
var float statGrossLossR = 0.0
var bool bullIfvgConfirmedAlert = false
var bool bearIfvgConfirmedAlert = false
var bool bullEntryAlert = false
var bool bearEntryAlert = false
var bool bullTrendlineBreakAlert = false
var bool bearTrendlineBreakAlert = false
bullIfvgConfirmedAlert := false, bearIfvgConfirmedAlert := false, bullEntryAlert := false, bearEntryAlert := false, bullTrendlineBreakAlert := false, bearTrendlineBreakAlert := false

//━━━━━━━━━━━━━━━━━━━━
// Auto Trendlines
//━━━━━━━━━━━━━━━━━━━━
phSrc = trendlineSource == "Body" ? math.max(open, close) : high
plSrc = trendlineSource == "Body" ? math.min(open, close) : low
ph = ta.pivothigh(phSrc, pivotLeft, pivotRight)
pl = ta.pivotlow(plSrc, pivotLeft, pivotRight)
var int prevPhBar = na
var int lastPhBar = na
var int prevPlBar = na
var int lastPlBar = na
var float prevPhVal = na
var float lastPhVal = na
var float prevPlVal = na
var float lastPlVal = na
var line resistanceLine = na
var line supportLine = na
if not na(ph)
    prevPhBar := lastPhBar, prevPhVal := lastPhVal, lastPhBar := bar_index - pivotRight, lastPhVal := ph
    if not na(prevPhBar)
        resistanceLine := line.new(prevPhBar, prevPhVal, lastPhBar, lastPhVal, color=bearTrendlineColor, width=trendlineWidth, extend=extendTrendlinesRight ? extend.right : extend.none)
        array.push(trendlines, resistanceLine)
if not na(pl)
    prevPlBar := lastPlBar, prevPlVal := lastPlVal, lastPlBar := bar_index - pivotRight, lastPlVal := pl
    if not na(prevPlBar)
        supportLine := line.new(prevPlBar, prevPlVal, lastPlBar, lastPlVal, color=bullTrendlineColor, width=trendlineWidth, extend=extendTrendlinesRight ? extend.right : extend.none)
        array.push(trendlines, supportLine)
if not (showTrendlinesMaster and showTrendlines)
    if array.size(trendlines) > 0
        for i = array.size(trendlines) - 1 to 0
            line.delete(array.get(trendlines, i))
            array.remove(trendlines, i)
if maxTrendlinesShown > 0
    while array.size(trendlines) > math.min(maxTrendlinesShown, trendlineDisplayCap == 0 ? maxTrendlinesShown : trendlineDisplayCap)
        oldTl = array.shift(trendlines)
        line.delete(oldTl)

resVal = f_lineValue(resistanceLine)
supVal = f_lineValue(supportLine)
bullBreakNow = not na(resVal) and (breakConfirmation == "Close" ? ta.crossover(close, resVal) : high > resVal and high[1] <= resVal[1])
bearBreakNow = not na(supVal) and (breakConfirmation == "Close" ? ta.crossunder(close, supVal) : low < supVal and low[1] >= supVal[1])
var int lastBullTrendBreakBar = na
var int lastBearTrendBreakBar = na
var int lastSupportRejectBar = na
var int lastResistanceRejectBar = na
if bullBreakNow
    lastBullTrendBreakBar := bar_index, bullTrendlineBreakAlert := true
    if not na(resistanceLine)
        line.set_color(resistanceLine, brokenTrendlineColor)
if bearBreakNow
    lastBearTrendBreakBar := bar_index, bearTrendlineBreakAlert := true
    if not na(supportLine)
        line.set_color(supportLine, brokenTrendlineColor)
if not na(supVal) and low <= supVal and close > supVal
    lastSupportRejectBar := bar_index
if not na(resVal) and high >= resVal and close < resVal
    lastResistanceRejectBar := bar_index
bullBreakRecent = not na(lastBullTrendBreakBar) and (trendlineBreakLookback == 0 or bar_index - lastBullTrendBreakBar <= trendlineBreakLookback)
bearBreakRecent = not na(lastBearTrendBreakBar) and (trendlineBreakLookback == 0 or bar_index - lastBearTrendBreakBar <= trendlineBreakLookback)
supportRejectRecent = not na(lastSupportRejectBar) and (trendlineBreakLookback == 0 or bar_index - lastSupportRejectBar <= trendlineBreakLookback)
resistanceRejectRecent = not na(lastResistanceRejectBar) and (trendlineBreakLookback == 0 or bar_index - lastResistanceRejectBar <= trendlineBreakLookback)
trendLongOk = not useTrendlineFilter or trendlineMode == "Off" ? true : trendlineMode == "Bias Only" ? (na(resVal) or close > resVal or bullBreakRecent) : trendlineMode == "Break Required" ? bullBreakRecent : supportRejectRecent
trendShortOk = not useTrendlineFilter or trendlineMode == "Off" ? true : trendlineMode == "Bias Only" ? (na(supVal) or close < supVal or bearBreakRecent) : trendlineMode == "Break Required" ? bearBreakRecent : resistanceRejectRecent

//━━━━━━━━━━━━━━━━━━━━
// FVG Detection / IFVG Confirmation
//━━━━━━━━━━━━━━━━━━━━
bullFvgFound = bar_index >= 2 and high[2] < low
bearFvgFound = bar_index >= 2 and low[2] > high
if bullFvgFound
    fvgTop = low, fvgBottom = high[2]
    sizeOk = not fvgSizeFilterEnabled or f_sizeValue(fvgTop, fvgBottom, fvgSizeMode, atrValue) >= minFvgSize
    if sizeOk
        latestBullFvgBar := bar_index, latestBullTop := fvgTop, latestBullBottom := fvgBottom, latestBullActive := true, latestBullIfvgConfirmed := false, latestBullIfvgBar := na, latestBullSignalDone := false, latestBullUpperContext := upperFvgContext, pendingBearRetest := false
        if showFvgs and showBullFvg
            latestBullBox := box.new(bar_index - 2, fvgTop, bar_index, fvgBottom, border_color=color.new(bullFvgColor, 0), bgcolor=color.new(bullFvgColor, fvgTransparency), extend=extend.none)
            array.push(bullBoxes, latestBullBox)
            latestBullFvgLabel := f_createCoreFvgLabel(bar_index, fvgTop, fvgBottom, "FVG", bullFvgColor)
            array.push(bullFvgLabels, latestBullFvgLabel)
            latestBullMidline := na
            if showMidline
                mid = (fvgTop + fvgBottom) * 0.5
                latestBullMidline := line.new(bar_index - 2, mid, bar_index, mid, color=midlineColor, style=f_midlineStyle(midlineStyleInput), extend=extend.none)
                array.push(bullMidlines, latestBullMidline)
if bearFvgFound
    fvgTop = low[2], fvgBottom = high
    sizeOk = not fvgSizeFilterEnabled or f_sizeValue(fvgTop, fvgBottom, fvgSizeMode, atrValue) >= minFvgSize
    if sizeOk
        latestBearFvgBar := bar_index, latestBearTop := fvgTop, latestBearBottom := fvgBottom, latestBearActive := true, latestBearIfvgConfirmed := false, latestBearIfvgBar := na, latestBearSignalDone := false, latestBearLowerContext := lowerFvgContext, pendingBullRetest := false
        if showFvgs and showBearFvg
            latestBearBox := box.new(bar_index - 2, fvgTop, bar_index, fvgBottom, border_color=color.new(bearFvgColor, 0), bgcolor=color.new(bearFvgColor, fvgTransparency), extend=extend.none)
            array.push(bearBoxes, latestBearBox)
            latestBearFvgLabel := f_createCoreFvgLabel(bar_index, fvgTop, fvgBottom, "FVG", bearFvgColor)
            array.push(bearFvgLabels, latestBearFvgLabel)
            latestBearMidline := na
            if showMidline
                mid = (fvgTop + fvgBottom) * 0.5
                latestBearMidline := line.new(bar_index - 2, mid, bar_index, mid, color=midlineColor, style=f_midlineStyle(midlineStyleInput), extend=extend.none)
                array.push(bearMidlines, latestBearMidline)

if extendFvgRight
    for b in bullBoxes
        box.set_right(b, bar_index)
    for b in bearBoxes
        box.set_right(b, bar_index)
    for l in bullMidlines
        line.set_x2(l, bar_index)
    for l in bearMidlines
        line.set_x2(l, bar_index)

f_cleanupVisuals(bullBoxes, bullMidlines, fvgDisplayCap), f_cleanupVisuals(bearBoxes, bearMidlines, fvgDisplayCap), f_cleanupLabels(bullFvgLabels, fvgDisplayCap), f_cleanupLabels(bearFvgLabels, fvgDisplayCap)

if latestBullActive and not latestBullIfvgConfirmed
    rightEdge = bar_index + 10
    if not na(latestBullBox)
        box.set_right(latestBullBox, rightEdge)
    f_updateCoreFvgLabel(latestBullFvgLabel, rightEdge, latestBullTop, latestBullBottom, "FVG", bullFvgColor)
    if not na(latestBullMidline)
        line.set_x2(latestBullMidline, f_labelAttachX(latestBullFvgLabel, rightEdge))
if latestBearActive and not latestBearIfvgConfirmed
    rightEdge = bar_index + 10
    if not na(latestBearBox)
        box.set_right(latestBearBox, rightEdge)
    f_updateCoreFvgLabel(latestBearFvgLabel, rightEdge, latestBearTop, latestBearBottom, "FVG", bearFvgColor)
    if not na(latestBearMidline)
        line.set_x2(latestBearMidline, f_labelAttachX(latestBearFvgLabel, rightEdge))

longFormationContextOk = not requireBandContextAtFvgCreation or latestBearLowerContext
shortFormationContextOk = not requireBandContextAtFvgCreation or latestBullUpperContext
longConfirmContextOk = not requireBandContextAtIfvgConfirm or lowerBandContextNow
shortConfirmContextOk = not requireBandContextAtIfvgConfirm or upperBandContextNow

if latestBearActive and not latestBearIfvgConfirmed
    barsFromCreate = bar_index - latestBearFvgBar
    if ifvgConfirmBarLimit == 0 or barsFromCreate <= ifvgConfirmBarLimit
        if barstate.isconfirmed and close > latestBearTop and longFormationContextOk and longConfirmContextOk
            latestBearIfvgConfirmed := true, latestBearIfvgBar := bar_index, bullIfvgConfirmedAlert := true
            if entryMode == "First IFVG Retest"
                pendingBullRetest := true, pendingBullRetestBar := bar_index
            if not na(latestBearBox)
                box.set_bgcolor(latestBearBox, color.new(bullFvgColor, fvgTransparency)), box.set_border_color(latestBearBox, color.new(bullFvgColor, 0))
            f_updateCoreFvgLabel(latestBearFvgLabel, bar_index + 10, latestBearTop, latestBearBottom, "IFVG", bullFvgColor)
    else
        latestBearActive := false
if latestBullActive and not latestBullIfvgConfirmed
    barsFromCreate = bar_index - latestBullFvgBar
    if ifvgConfirmBarLimit == 0 or barsFromCreate <= ifvgConfirmBarLimit
        if barstate.isconfirmed and close < latestBullBottom and shortFormationContextOk and shortConfirmContextOk
            latestBullIfvgConfirmed := true, latestBullIfvgBar := bar_index, bearIfvgConfirmedAlert := true
            if entryMode == "First IFVG Retest"
                pendingBearRetest := true, pendingBearRetestBar := bar_index
            if not na(latestBullBox)
                box.set_bgcolor(latestBullBox, color.new(bearFvgColor, fvgTransparency)), box.set_border_color(latestBullBox, color.new(bearFvgColor, 0))
            f_updateCoreFvgLabel(latestBullFvgLabel, bar_index + 10, latestBullTop, latestBullBottom, "IFVG", bearFvgColor)
    else
        latestBullActive := false

//━━━━━━━━━━━━━━━━━━━━
// Entry Logic / Trade Creation
//━━━━━━━━━━━━━━━━━━━━
labelSz = f_labelSize(entryLabelSizeInput)
entryOffset = math.max(syminfo.mintick * 10.0, atrValue * entryMarkerOffsetAtrMult)
bullRetestEntry = pendingBullRetest and bar_index > pendingBullRetestBar and bar_index - pendingBullRetestBar <= maxRetestBars and low <= latestBearTop and close > latestBearBottom
bearRetestEntry = pendingBearRetest and bar_index > pendingBearRetestBar and bar_index - pendingBearRetestBar <= maxRetestBars and high >= latestBullBottom and close < latestBullTop
if pendingBullRetest and bar_index - pendingBullRetestBar > maxRetestBars
    pendingBullRetest := false
if pendingBearRetest and bar_index - pendingBearRetestBar > maxRetestBars
    pendingBearRetest := false
longSignal = barstate.isconfirmed and latestBearActive and latestBearIfvgConfirmed and not latestBearSignalDone and ((entryMode == "IFVG Close" and bar_index == latestBearIfvgBar) or (entryMode == "First IFVG Retest" and bullRetestEntry)) and trendLongOk and sessionVwapBullOk
shortSignal = barstate.isconfirmed and latestBullActive and latestBullIfvgConfirmed and not latestBullSignalDone and ((entryMode == "IFVG Close" and bar_index == latestBullIfvgBar) or (entryMode == "First IFVG Retest" and bearRetestEntry)) and trendShortOk and sessionVwapBearOk

f_addDashTrade(int dir, float entryV, float stopV, float riskV, float beV, float tpV) =>
    array.push(dashTradeDirs, dir), array.push(dashTradeActive, true), array.push(dashTradeEntries, entryV), array.push(dashTradeStops, stopV), array.push(dashTradeBEs, beV), array.push(dashTradeTPs, tpV), array.push(dashTradeRisks, riskV), array.push(dashTradeMovedToEntry, false)

f_addVisualTrade(int dir, float entryV, float stopV, float beV, float r2V, float r3V) =>
    [lnE, lbE] = f_makeTradeLevel(entryV, "Entry", entryLineColor, tradeLineWidth)
    [lnS, lbS] = f_makeTradeLevel(stopV, "Stop", stopLineColor, tradeLineWidth)
    [lnB, lbB] = f_makeTradeLevel(beV, "BE / 1R", beLineColor, tradeLineWidth)
    [ln2, lb2] = f_makeTradeLevel(r2V, "2R", r2LineColor, tradeLineWidth)
    [ln3, lb3] = f_makeTradeLevel(r3V, "3R", r3LineColor, tradeLineWidth)
