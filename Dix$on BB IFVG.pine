    beV = entryV - riskV, r2V = entryV - riskV * 2.0, r3V = entryV - riskV * 3.0, tpV = endTradeLevel == "1R" ? beV : endTradeLevel == "3R" ? r3V : r2V
    f_addDashTrade(-1, entryV, stopV, riskV, beV, tpV)
    if showEntries
        array.push(bearEntries, label.new(bar_index, high + entryOffset, "Short", style=label.style_label_down, color=shortEntryLabelColor, textcolor=entryLabelTextColor, size=labelSz))
    if showIfvgEntryZones
        [entryFvgBox, entryFvgMid] = f_createEntryFvgVisual(latestBullFvgBar - 2, latestBullTop, latestBullBottom, bearFvgColor, fvgTransparency, showMidline, midlineColor, midlineStyleInput)
        array.push(bearEntryFvgBoxes, entryFvgBox), array.push(bearEntryFvgLabels, f_createCoreFvgLabel(bar_index, latestBullTop, latestBullBottom, "IFVG", bearFvgColor))
        if not na(entryFvgMid)
            array.push(bearEntryFvgMidlines, entryFvgMid)
