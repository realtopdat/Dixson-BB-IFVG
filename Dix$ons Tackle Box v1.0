// Arrays (shared across engines)
var float[] ratios = array.from(
     fibLevel0,fibLevel1,fibLevel2,fibLevel3,fibLevel4,
     fibLevel5,fibLevel6,fibLevel7,fibLevel8,fibLevel9,
     fibLevel10,fibLevel11,fibLevel12,fibLevel13,fibLevel14)

var bool[]  ena    = array.from(
     enableFibLevel0,enableFibLevel1,enableFibLevel2,enableFibLevel3,enableFibLevel4,
     enableFibLevel5,enableFibLevel6,enableFibLevel7,enableFibLevel8,enableFibLevel9,
     enableFibLevel10,enableFibLevel11,enableFibLevel12,enableFibLevel13,enableFibLevel14)

var color[] cols   = array.from(
     fibColor0,fibColor1,fibColor2,fibColor3,fibColor4,
     fibColor5,fibColor6,fibColor7,fibColor8,fibColor9,
     fibColor10,fibColor11,fibColor12,fibColor13,fibColor14)

var int[]   wts    = array.from(
     fibThickness0,fibThickness1,fibThickness2,fibThickness3,fibThickness4,
     fibThickness5,fibThickness6,fibThickness7,fibThickness8,fibThickness9,
     fibThickness10,fibThickness11,fibThickness12,fibThickness13,fibThickness14)

var string[] styStr= array.from(
     fibStyle0,fibStyle1,fibStyle2,fibStyle3,fibStyle4,
     fibStyle5,fibStyle6,fibStyle7,fibStyle8,fibStyle9,
     fibStyle10,fibStyle11,fibStyle12,fibStyle13,fibStyle14)

// ─────────────────────────────────────────────────────────────────────────────
// Helpers
// ─────────────────────────────────────────────────────────────────────────────
f_lineStyle(_s) =>
    _s == "Dashed" ? line.style_dashed : _s == "Dotted" ? line.style_dotted : line.style_solid

f_calc(_lo,_hi,_r) =>
    lo = useLog ? math.log(_lo) : _lo
    hi = useLog ? math.log(_hi) : _hi
    v  = lo + (hi - lo) * _r
    useLog ? math.exp(v) : v

f_calc_dir(_a, _b, _r) =>
    a = useLog ? math.log(_a) : _a
    b = useLog ? math.log(_b) : _b
    x = a + (b - a) * _r
    useLog ? math.exp(x) : x

// NEW: fib-specific label size + sized label/bank helpers
f_fibLblSize(_s) =>
    switch _s
        "tiny"   => size.tiny
        "small"  => size.small
        "normal" => size.normal
        "large"  => size.large
        "huge"   => size.huge
        => size.tiny

// left-aligned, attached at the ray’s right end (offset + length)
f_lbl(on, price, txt, c, xoff, old) =>
    if not na(old)
        label.delete(old)
    var label n = na
    if on and not na(price) and barstate.islast
        n := label.new(bar_index + xoff, price, text      = txt, style     = label.style_none, textalign = text.align_left, yloc      = yloc.price, color     = color.new(color.black, 100), textcolor = c, size      = size.tiny)
    n

// NEW: same as f_lbl but with custom size
f_lbl_sz(on, price, txt, c, xoff, old, _sz) =>
    if not na(old)
        label.delete(old)
    var label n = na
    if on and not na(price) and barstate.islast
        n := label.new(bar_index + xoff, price, text=txt, style=label.style_none, textalign=text.align_left, yloc=yloc.price, color=color.new(color.black, 100), textcolor=c, size=_sz)
    n

f_draw_bank(_lo, _hi, _offset, _len, _lnArr, _valArr) =>
    for i = 0 to array.size(ratios) - 1
        if array.get(ena, i) and not na(_lo) and not na(_hi)
            v  = f_calc(_lo, _hi, array.get(ratios,i))
            array.set(_valArr, i, v)
            line.delete(array.get(_lnArr, i))
            array.set(_lnArr, i, line.new(bar_index + _offset, v, bar_index + _offset + _len, v, color=array.get(cols, i), width=array.get(wts, i), style=f_lineStyle(array.get(styStr, i))))

f_draw_bank_dir(_a, _b, _offset, _len, _lnArr, _valArr) =>
    for i = 0 to array.size(ratios) - 1
        if array.get(ena, i) and not na(_a) and not na(_b)
            v  = f_calc_dir(_a, _b, array.get(ratios, i))
            array.set(_valArr, i, v)
            line.delete(array.get(_lnArr, i))
            array.set(_lnArr, i, line.new(bar_index + _offset, v, bar_index + _offset + _len, v, color=array.get(cols, i), width=array.get(wts, i), style=f_lineStyle(array.get(styStr, i))))

// place labels at ray end (offset + length) — now with "$" before price
f_label_bank(_vals, _lblArr, _xoff, _prefix, _showText, _showPrice, _pct, _lenForLabels) =>
    for i = 0 to array.size(ratios) - 1
        label old = array.get(_lblArr, i)
        base = _pct ? str.tostring(array.get(ratios,i)*100, "#.##")+"%" : str.tostring(array.get(ratios,i), "#.###")
        t = _showText ? (_prefix != "" ? _prefix+" "+base : base) : ""
        if _showPrice
            priceTxt = "$" + str.tostring(array.get(_vals,i), format.mintick)
            t := t == "" ? priceTxt : (t + " / " + priceTxt)
        array.set(_lblArr, i, f_lbl(array.get(ena,i), array.get(_vals,i), t, array.get(cols,i), _xoff + _lenForLabels, old))

// NEW: sized variant (uses f_lbl_sz)
f_label_bank_sz(_vals, _lblArr, _xoff, _prefix, _showText, _showPrice, _pct, _lenForLabels, _sz) =>
    for i = 0 to array.size(ratios) - 1
        label old = array.get(_lblArr, i)
        base = _pct ? str.tostring(array.get(ratios,i)*100, "#.##")+"%" : str.tostring(array.get(ratios,i), "#.###")
        t = _showText ? (_prefix != "" ? _prefix+" "+base : base) : ""
        if _showPrice
            priceTxt = "$" + str.tostring(array.get(_vals,i), format.mintick)
            t := t == "" ? priceTxt : (t + " / " + priceTxt)
        array.set(_lblArr, i, f_lbl_sz(array.get(ena,i), array.get(_vals,i), t, array.get(cols,i), _xoff + _lenForLabels, old, _sz))


// ─────────────────────────────────────────────────────────────────────────────
// ATR engine  (Prev ATR Fib independent of enableFib_STA)
// ─────────────────────────────────────────────────────────────────────────────
var int   sta_det        = 0
var int   sta_prevDet    = 0
var float sta_anchorH    = na
var float sta_anchorL    = na
var float sta_priorStart = na
var float sta_priorEnd   = na
var float sta_trStop     = na
var float sta_trDir      = 0.0
var color sta_visStopColor = color.yellow

var line[]  sta_curLns   = array.new_line(15)
var float[] sta_curVals  = array.new_float(15)
var label[] sta_curLbls  = array.new_label(15)
var line[]  sta_prevLns  = array.new_line(15)
var float[] sta_prevVals = array.new_float(15)
var label[] sta_prevLbls = array.new_label(15)

// NOTE: Compute ATR engine state whenever enableAutoFib is true.
// Current ATR Fib drawing is gated by enableFib_STA.
// Previous ATR Fib drawing is gated ONLY by enableFib_STA_P.
if enableAutoFib
    atr_now = ta.atr(sta_atrLen)
    [st_val_builtin, st_dir_builtin] = ta.supertrend(sta_atrMult, sta_atrLen)
    st_val_series = barstate.isfirst ? na : st_val_builtin
    newDir = (st_dir_builtin < 0) ? 1 : -1

    // Gap (no-touch) via ATR only
    gap = atr_now * sta_proxATR

    hiRaw  = high + gap
    loRaw  = low  - gap
    hiPush = ta.rma(high + gap, 3)
    loPush = ta.rma(low  - gap, 3)

    var float railH = na
    var float railL = na
    if na(railH) or na(railL)
        railH := hiRaw
        railL := loRaw
        sta_trStop := st_val_series
        sta_trDir  := (st_dir_builtin < 0 ? 1.0 : -1.0)
        sta_det        := 0
        sta_prevDet    := 0
        sta_priorStart := na
        sta_priorEnd   := na

    prevPubH = nz(sta_anchorH[1], railH)
    prevPubL = nz(sta_anchorL[1], railL)

    if newDir != sta_det
        if sta_det != 0
            sta_prevDet    := sta_det
            sta_priorStart := (sta_det == 1) ? prevPubH : prevPubL
            sta_priorEnd   := (sta_det == 1) ? prevPubL : prevPubH
        sta_det := newDir

        if sta_det == 1
            railL := prevPubL
            railH := hiRaw
        else
            railH := prevPubH
            railL := loRaw
    else
        if sta_det == 1
            railH := math.max(prevPubH, hiPush)
            railL := prevPubL
        else if sta_det == -1
            railL := math.min(prevPubL, loPush)
            railH := prevPubH
        else
            railH := hiRaw
            railL := loRaw

    if railL > railH
        midFix = (railL + railH) * 0.5
        railL := midFix
        railH := midFix

    // hard no-touch clamp (keep outside candle)
    railH := math.max(railH, high + gap)
    railL := math.min(railL, low  - gap)

    // Supertrend visual (continuous), clamped for display only
    st_clamped       = math.min(math.max(st_val_series, railL), railH)
    sta_trStop       := st_clamped
    sta_visStopColor := (st_dir_builtin < 0) ? color.lime : color.red

    // Publish rails
    sta_anchorH := railH
    sta_anchorL := railL

    // CURRENT ATR fib — draws only if enableFib_STA is on
    if enableFib_STA and sta_det != 0
        cur0 = (sta_det == 1) ? sta_anchorH : sta_anchorL
        cur1 = (sta_det == 1) ? sta_anchorL : sta_anchorH
        f_draw_bank_dir(cur0, cur1, sta_curOffset, sta_rayLen, sta_curLns, sta_curVals)
        f_label_bank_sz(sta_curVals, sta_curLbls, sta_curOffset, "", sta_showText, sta_showPrice, sta_pct, sta_rayLen, f_fibLblSize(sta_labelSize))

    // PREVIOUS ATR fib — independent of enableFib_STA
    if enableFib_STA_P and sta_prevDet != 0 and not na(sta_priorStart) and not na(sta_priorEnd)
        f_draw_bank_dir(sta_priorStart, sta_priorEnd, sta_priorOffset, sta_priorLen, sta_prevLns, sta_prevVals)
        f_label_bank_sz(sta_prevVals, sta_prevLbls, sta_priorOffset, "Prev", staP_showText, staP_showPrice, staP_pct, sta_priorLen, f_fibLblSize(staP_labelSize))
else
    na

// ── GLOBAL PLOTS (unchanged; still tied to current ATR Fib visuals)
plot((sta_plotHL  and enableAutoFib and enableFib_STA) ? sta_anchorH : na, title="ATR Anchor High", color=color.new(color.white, 0), style=plot.style_line,   linewidth=2)
plot((sta_plotHL  and enableAutoFib and enableFib_STA) ? sta_anchorL : na, title="ATR Anchor Low",  color=color.new(color.white, 0), style=plot.style_line,   linewidth=2)
plot((sta_plotATR and enableAutoFib and enableFib_STA) ? sta_trStop  : na, title="Supertrend (continuous)", color=sta_visStopColor, style=plot.style_linebr, linewidth=2)


// ─────────────────────────────────────────────────────────────────────────────
// LOOKBACK engine (ATR-style flow) — uses HH/LL on lb_tf for anchors
// Trend = which extreme is MOST RECENT inside the lookback window
// Draw direction & flip capture mirrors your ATR engine for visual consistency
// ─────────────────────────────────────────────────────────────────────────────
var int   lb_det         = 0          // 1 = up (recent High), -1 = down (recent Low)
var int   lb_prevDet     = 0
var float lb_anchorH     = na         // published “railH” equivalent = lookback HH
var float lb_anchorL     = na         // published “railL” equivalent = lookback LL
var float lb_priorStart  = na         // previous segment start (for optional prev draw later)
var float lb_priorEnd    = na

var line[]  lb_curLns    = array.new_line(15)
var float[] lb_curVals   = array.new_float(15)
var label[] lb_curLbls   = array.new_label(15)

// NOTE: logic unchanged from your latest “SMA-less lookback” version; only names updated.
if enableAutoFib and enableFib_LB
    // Selected TF + lookahead mode
    _tf     = (lb_tf == "" ? timeframe.period : lb_tf)
    _laMode = lb_lookaheadBars > 0 ? barmerge.lookahead_on : barmerge.lookahead_off

    // Compute HH/LL AND their “bars back” on the selected timeframe (no interpolation)
    _hiVal = request.security(syminfo.tickerid, _tf, ta.highest(high,     lb_lookback),     lookahead=_laMode, gaps=barmerge.gaps_off)
    _loVal = request.security(syminfo.tickerid, _tf, ta.lowest( low,      lb_lookback),     lookahead=_laMode, gaps=barmerge.gaps_off)
    _hiOff = request.security(syminfo.tickerid, _tf, ta.highestbars(high, lb_lookback),     lookahead=_laMode, gaps=barmerge.gaps_off)
    _loOff = request.security(syminfo.tickerid, _tf, ta.lowestbars( low,  lb_lookback),     lookahead=_laMode, gaps=barmerge.gaps_off)

    // MOST RECENT extreme decides direction (ties keep prior)
    recentHigh = _hiOff < _loOff
    recentLow  = _loOff < _hiOff
    newDet = lb_forceUp ? 1 : lb_forceDown ? -1 : (recentHigh ? 1 : (recentLow ? -1 : lb_det))

    // Manual override wins if both provided (kept exactly like before)
    if (highO > 0 and lowO > 0)
        newDet := highO > lowO ? 1 : -1

    // Flip handling (mirror ATR engine)
    if newDet != lb_det and lb_det != 0
        lb_prevDet    := lb_det
        // Mirror ATR’s “priorStart/priorEnd” convention:
        //  uptrend prior = H → L ; downtrend prior = L → H
        lb_priorStart := (lb_det == 1) ? nz(lb_anchorH, _hiVal) : nz(lb_anchorL, _loVal)
        lb_priorEnd   := (lb_det == 1) ? nz(lb_anchorL, _loVal) : nz(lb_anchorH, _hiVal)

    // Commit direction
    lb_det := newDet

    // Publish anchors = raw lookback HH/LL (no ATR “push”)
    // If manual anchors are provided, force them (exactly like before)
    lb_anchorH := (highO > 0 and lowO > 0) ? highO : _hiVal
    lb_anchorL := (highO > 0 and lowO > 0) ? lowO  : _loVal

    // CURRENT Lookback fib — directional draw:
    //  Uptrend  => draw LOW → HIGH
    //  Downtrend => draw HIGH → LOW
    if lb_det != 0
        cur0 = (lb_det == 1) ? lb_anchorL : lb_anchorH
        cur1 = (lb_det == 1) ? lb_anchorH : lb_anchorL
        f_draw_bank_dir(cur0, cur1, lb_curOffset, lb_rayLen, lb_curLns, lb_curVals)
        // Label prefix and size updated to “LB”
        f_label_bank_sz(lb_curVals, lb_curLbls, lb_curOffset, "LB", lb_showText, lb_showPrice, lb_pct, lb_rayLen, f_fibLblSize(lb_labelSize))
else
    na
