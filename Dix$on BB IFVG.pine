selectedBasis = bandTouchSource == "Chart Bands" ? bbBasis : htfBasis
selectedUpper = bandTouchSource == "Chart Bands" ? bbUpper : htfUpper
selectedLower = bandTouchSource == "Chart Bands" ? bbLower : htfLower
selectedBandwidth = bandTouchSource == "Chart Bands" ? bbBandwidth : htfBandwidth
bbState = close > selectedUpper ? "Upper Extreme" : close < selectedLower ? "Lower Extreme" : selectedBandwidth < nz(ta.sma(selectedBandwidth, 20)) * 0.75 ? "Squeeze" : selectedBandwidth > nz(ta.sma(selectedBandwidth, 20)) * 1.25 ? "Expansion" : close >= selectedBasis ? "Above Mid" : close < selectedBasis ? "Below Mid" : "Inside Bands"
