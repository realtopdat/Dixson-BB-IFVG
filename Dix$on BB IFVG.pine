f_cleanupLabels(bullEntries, entryDisplayCap), f_cleanupLabels(bearEntries, entryDisplayCap)
f_cleanupVisuals(bullEntryFvgBoxes, bullEntryFvgMidlines, ifvgEntryZoneCap), f_cleanupVisuals(bearEntryFvgBoxes, bearEntryFvgMidlines, ifvgEntryZoneCap)
f_cleanupLabels(bullEntryFvgLabels, ifvgEntryZoneCap), f_cleanupLabels(bearEntryFvgLabels, ifvgEntryZoneCap)

// Trade visual caps and lifecycle.
if not keepActiveTrades and array.size(tradeEntryLines) > 0
    for j = array.size(tradeEntryLines) - 1 to 0
        if array.get(tradeIsActive, j)
            f_deleteTradeAt(j, tradeEntryLines, tradeStopLines, tradeBeLines, tradeR2Lines, tradeR3Lines, tradeEntryLabels, tradeStopLabels, tradeBeLabels, tradeR2Labels, tradeR3Labels, tradeDirs, tradeIsActive, tradeStops, tradeBEs, tradeTps, tradeEntries, tradeMovedToEntry)
if activeTradeCap > 0
    activeCount = 0
    for a in tradeIsActive
        if a
            activeCount += 1
    while activeCount > activeTradeCap and array.size(tradeIsActive) > 0
        int oldestActive = -1
        for j = 0 to array.size(tradeIsActive) - 1
            if array.get(tradeIsActive, j)
                oldestActive := j
                break
        if oldestActive >= 0
            f_deleteTradeAt(oldestActive, tradeEntryLines, tradeStopLines, tradeBeLines, tradeR2Lines, tradeR3Lines, tradeEntryLabels, tradeStopLabels, tradeBeLabels, tradeR2Labels, tradeR3Labels, tradeDirs, tradeIsActive, tradeStops, tradeBEs, tradeTps, tradeEntries, tradeMovedToEntry)
            activeCount -= 1
        else
            break
if array.size(tradeEntryLines) > 0
    tradeRightEdge = bar_index + 10
    for i = 0 to array.size(tradeEntryLines) - 1
        if array.get(tradeIsActive, i)
            line.set_x2(array.get(tradeEntryLines, i), tradeRightEdge), line.set_x2(array.get(tradeBeLines, i), tradeRightEdge), line.set_x2(array.get(tradeR2Lines, i), tradeRightEdge), line.set_x2(array.get(tradeR3Lines, i), tradeRightEdge)
            if not na(array.get(tradeStopLines, i))
                line.set_x2(array.get(tradeStopLines, i), tradeRightEdge)
            label.set_x(array.get(tradeEntryLabels, i), tradeRightEdge), label.set_x(array.get(tradeBeLabels, i), tradeRightEdge), label.set_x(array.get(tradeR2Labels, i), tradeRightEdge), label.set_x(array.get(tradeR3Labels, i), tradeRightEdge)
            if not na(array.get(tradeStopLabels, i))
                label.set_x(array.get(tradeStopLabels, i), tradeRightEdge)

hitHi = tradeHitMode == "Body" ? math.max(open, close) : high
hitLo = tradeHitMode == "Body" ? math.min(open, close) : low
if array.size(tradeEntryLines) > 0
    for i = array.size(tradeEntryLines) - 1 to 0
        if array.get(tradeIsActive, i)
            dir = array.get(tradeDirs, i), stopV = array.get(tradeStops, i), beV = array.get(tradeBEs, i), tpV = array.get(tradeTps, i), entryV = array.get(tradeEntries, i), moved = array.get(tradeMovedToEntry, i)
            beHit = dir == 1 ? hitHi >= beV : hitLo <= beV
            if not moved and beHit
                array.set(tradeMovedToEntry, i, true), array.set(tradeStops, i, entryV), stopV := entryV
                slLine = array.get(tradeStopLines, i), slLabel = array.get(tradeStopLabels, i)
