                break
        if oldestEnded >= 0
            f_deleteTradeAt(oldestEnded, tradeEntryLines, tradeStopLines, tradeBeLines, tradeR2Lines, tradeR3Lines, tradeEntryLabels, tradeStopLabels, tradeBeLabels, tradeR2Labels, tradeR3Labels, tradeDirs, tradeIsActive, tradeStops, tradeBEs, tradeTps, tradeEntries, tradeMovedToEntry)
            endedCount -= 1
        else
            break

// Performance lifecycle.
if array.size(dashTradeDirs) > 0
    for i = array.size(dashTradeDirs) - 1 to 0
