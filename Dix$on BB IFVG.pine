activeTradeTxt = activeDir == 1 ? "Long" : activeDir == -1 ? "Short" : "None"
currentR = activeDir == 1 and activeRisk > 0 ? (close - activeEntry) / activeRisk : activeDir == -1 and activeRisk > 0 ? (activeEntry - close) / activeRisk : na
