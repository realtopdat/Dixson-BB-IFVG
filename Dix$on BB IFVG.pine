        f_dashCell(liveDashboard, 0, 7, "Active Trade", color.white, dashLabelBg, dashboardTextSizeInput), f_dashCell(liveDashboard, 1, 7, activeTradeTxt, color.white, activeDir == 1 ? dashBullBg : activeDir == -1 ? dashBearBg : dashNeutralBg, dashboardTextSizeInput)
        f_dashCell(liveDashboard, 0, 8, "Entry", color.white, dashLabelBg, dashboardTextSizeInput), f_dashCell(liveDashboard, 1, 8, f_fmtPrice(activeEntry), color.white, dashNeutralBg, dashboardTextSizeInput)
        f_dashCell(liveDashboard, 0, 9, "Stop", color.white, dashLabelBg, dashboardTextSizeInput), f_dashCell(liveDashboard, 1, 9, f_fmtPrice(activeStop), color.white, dashNeutralBg, dashboardTextSizeInput)
