if showTradeHistory and tradeLevelHistory > 0
    endedCount = 0
    for a in tradeIsActive
        if not a
            endedCount += 1
    while endedCount > tradeLevelHistory and array.size(tradeIsActive) > 0
        int oldestEnded = -1
        for i = 0 to array.size(tradeIsActive) - 1
            if not array.get(tradeIsActive, i)
