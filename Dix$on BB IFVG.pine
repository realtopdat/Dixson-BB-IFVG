        f_dashCell(liveDashboard, 0, 11, "TP", color.white, dashLabelBg, dashboardTextSizeInput), f_dashCell(liveDashboard, 1, 11, f_fmtPrice(activeTP), color.white, dashNeutralBg, dashboardTextSizeInput)
